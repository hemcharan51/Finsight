# Copy to .env and fill in to enable live Claude calls.
# When unset, FinSight runs in deterministic MOCK mode — the full grid pipeline
# still executes end-to-end on the bundled demo dataset, with no network calls.

ANTHROPIC_API_KEY=

# Model routing (Layer 07 — D×C cost tax mitigation).
# Simple extraction cells use the small model; hard cells / planning / synthesis
# use the large model.
FINSIGHT_MODEL_SMALL=claude-haiku-4-5-20251001
FINSIGHT_MODEL_LARGE=claude-opus-4-8

# Per-cell fan-out concurrency cap (semaphore).
FINSIGHT_MAX_CONCURRENCY=8

# Force mock mode even if a key is present (useful for tests / offline demos).
FINSIGHT_MOCK_LLM=false
